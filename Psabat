# rename.ps1

Write-Host "Starting rename operation..." -ForegroundColor Cyan

$files = Get-ChildItem -File -Filter "Mail from M3 *.pdf"

if ($files.Count -eq 0) {
    Write-Host "No matching files found!" -ForegroundColor Red
} else {
    foreach ($file in $files) {
        $num = $file.BaseName -replace '^Mail from M3\s*', ''
        if (\( num -match '^\d+ \)') {
            $newName = "DN $num.pdf"
            Rename-Item -LiteralPath $file.FullName -NewName $newName
            Write-Host "Renamed: $($file.Name)  -->  $newName" -ForegroundColor Green
        } else {
            Write-Host "Skipped (not a number): $($file.Name)" -ForegroundColor Yellow
        }
    }
}

Write-Host "All done!" -ForegroundColor Cyan
pause
